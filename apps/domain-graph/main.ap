// domain-graph — m102 v0 (now agnostic over source language).
//
// Third of the three lotus towers. Bulk-mode view of a codebase:
// what concepts the code works with, derived from a deterministic
// morpheme rewriter on type names. **No LLM dep** — per
// notes/codebase-onboarding-design.md, the domain mapping is a
// rule-based transform (suffix rule + per-language entity-noun
// lookup table + explicit `<unknown:X>` markers).
//
// **Honesty about uncertainty preserves the recognition;
// over-claiming breaks it.** The unknown marker is non-negotiable
// at v0.
//
// **Language-agnostic body.** Type-declaration classification +
// name extraction route through `std::lang::Lang`. The
// morpheme rewriter is itself language-agnostic (English-grammar
// morphology; the lookup table seed is Go-flavored vocabulary
// but the rules apply broadly). Adding Rust / Python / TS is a
// `Lang` extension.
//
// **Lotus-everywhere ethos.** The morpheme rewriter is its own
// `MorphemeRewriterL` namespace lotus — empty `params { }`, only
// methods, no lifecycle. Use site instantiates once
// (`let r = MorphemeRewriterL { };`) and dispatches everything
// through `r.name_to_motion(...)`. Self-method calls within the
// locus keep the namespace coherent.
//
// Usage:
//   aperio build apps/domain-graph/main.ap
//   apps/domain-graph/main [SRC_DIR] [LANG_FLAVOR]

// MorphemeRewriterL — namespace lotus for the noun→motion
// transform. Empty params; pure methods.
locus MorphemeRewriterL {
    params { }

    fn is_upper(c: String) -> Bool {
        return std::str::index_of("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c) >= 0;
    }

    fn to_lower(s: String) -> String {
        let n = len(s);
        let mut out = "";
        let mut i = 0;
        while i < n {
            let c = s[i..i+1];
            let idx = std::str::index_of("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c);
            if idx >= 0 {
                out = out + "abcdefghijklmnopqrstuvwxyz"[idx..idx+1];
            } else {
                out = out + c;
            }
            i = i + 1;
        }
        return out;
    }

    fn ends_with(s: String, suffix: String) -> Bool {
        let sl = len(s);
        let xl = len(suffix);
        if sl < xl { return false; }
        return s[sl-xl..sl] == suffix;
    }

    // Per-morpheme entity-noun lookup. Returns "" on miss so the
    // caller falls through to the suffix rule.
    fn lookup_morpheme(m: String) -> String {
        if m == "Controller" { return "controlling"; }
        if m == "Processor"  { return "processing"; }
        if m == "Manager"    { return "managing"; }
        if m == "Handler"    { return "handling"; }
        if m == "Listener"   { return "listening"; }
        if m == "Validator"  { return "checking"; }
        if m == "Builder"    { return "building"; }
        if m == "Parser"     { return "parsing"; }
        if m == "Repository" { return "carrying"; }
        if m == "Cache"      { return "remembering"; }
        if m == "Bus"        { return "routing"; }
        if m == "Queue"      { return "queuing"; }
        if m == "Pool"       { return "pooling"; }
        if m == "Pipeline"   { return "flowing"; }
        if m == "Service"    { return "serving"; }
        return "";
    }

    // Suffix rule with min-morpheme-6 guard against fabrication
    // ("Order" → "Ord"+"ing" would be wrong; min-6 fails it).
    fn suffix_rule(m: String) -> String {
        let n = len(m);
        if n < 6 { return ""; }
        if self.ends_with(m, "er") {
            return self.to_lower(m[0..n-2]) + "ing";
        }
        if self.ends_with(m, "or") {
            return self.to_lower(m[0..n-2]) + "ing";
        }
        if self.ends_with(m, "ar") {
            return self.to_lower(m[0..n-2]) + "ing";
        }
        return "";
    }

    fn morpheme_to_motion(m: String) -> String {
        let hit = self.lookup_morpheme(m);
        if len(hit) > 0 { return hit; }
        let suf = self.suffix_rule(m);
        if len(suf) > 0 { return suf; }
        return "<unknown:" + m + ">";
    }

    fn split_camel(name: String) -> String {
        let n = len(name);
        if n == 0 { return ""; }
        let mut out = "";
        let mut start = 0;
        let mut i = 1;
        while i < n {
            let c = name[i..i+1];
            if self.is_upper(c) {
                out = out + name[start..i] + "\n";
                start = i;
            }
            i = i + 1;
        }
        out = out + name[start..n] + "\n";
        return out;
    }

    fn name_to_motion(name: String) -> String {
        let morphemes = self.split_camel(name);
        let total = len(morphemes);
        let mut out = "";
        let mut from = 0;
        let mut first = true;
        while from < total {
            let rest = morphemes[from..total];
            let nl = std::str::index_of(rest, "\n");
            let mut m = "";
            if nl < 0 {
                m = rest;
                from = total;
            } else {
                m = rest[0..nl];
                from = from + nl + 1;
            }
            if len(m) > 0 {
                let motion = self.morpheme_to_motion(m);
                if first {
                    out = motion;
                    first = false;
                } else {
                    out = out + "-" + motion;
                }
            }
        }
        return out;
    }
}

// Recurse only under a type-decl to find type-spec leaves.
// `lang` provides the per-flavor classifier; the recursion is
// grammar-agnostic.
fn __collect_type_specs(lang: std::lang::Lang, node: Int) -> String {
    if node == 0 { return ""; }
    if lang.is_type_spec(node) {
        return lang.extract_type_name(node) + "\n";
    }
    let mut acc = "";
    let cnt = std::ts::node_named_child_count(node);
    let mut i = 0;
    while i < cnt {
        let c = std::ts::node_named_child(node, i);
        acc = acc + __collect_type_specs(lang, c);
        i = i + 1;
    }
    return acc;
}

// Walk the file's root, collecting type-decl subtrees only.
// Avoids picking up type-spec nodes inside function bodies (Go
// allows local type declarations) by descending into the body
// of each `type_declaration` separately.
fn __collect_type_names(lang: std::lang::Lang, node: Int) -> String {
    if node == 0 { return ""; }
    let mut acc = "";
    if lang.is_type_decl(node) {
        acc = acc + __collect_type_specs(lang, node);
    }
    let cnt = std::ts::node_named_child_count(node);
    let mut i = 0;
    while i < cnt {
        let c = std::ts::node_named_child(node, i);
        if !lang.is_type_decl(node) {
            acc = acc + __collect_type_names(lang, c);
        }
        i = i + 1;
    }
    return acc;
}

fn __ends_with_source(name: String, flavor: String) -> Bool {
    let n = len(name);
    if flavor == "go" {
        if n < 3 { return false; }
        return name[n-3..n] == ".go";
    }
    return false;
}

fn __append_entry(arr: String, entry: String) -> String {
    if len(arr) == 0 { return entry; }
    return arr + ", " + entry;
}

fn __domain_drive(dir: String, flavor: String) {
    let lang = std::lang::Lang { flavor: flavor };
    let entries = std::io::fs::list_dir(dir);
    let total_e = len(entries);
    if total_e == 0 {
        println("{\"types\": [], \"error\": \"empty or unreadable dir\"}");
        return;
    }

    // One namespace-lotus instance for the whole walk.
    let r = MorphemeRewriterL { };

    let mut types_arr = "";
    let mut from = 0;
    while from < total_e {
        let rest = entries[from..total_e];
        let nl = std::str::index_of(rest, "\n");
        let mut name = "";
        if nl < 0 {
            name = rest;
            from = total_e;
        } else {
            name = rest[0..nl];
            from = from + nl + 1;
        }
        if len(name) > 0 {
            if __ends_with_source(name, flavor) {
                let path = dir + "/" + name;
                let src = std::io::fs::read_file(path);
                if len(src) > 0 {
                    let tree = lang.parse(src);
                    if tree != 0 {
                        let root = std::ts::root_node(tree);
                        let names = __collect_type_names(lang, root);
                        let nlen = len(names);
                        let mut nfrom = 0;
                        while nfrom < nlen {
                            let nrest = names[nfrom..nlen];
                            let nnl = std::str::index_of(nrest, "\n");
                            let mut tname = "";
                            if nnl < 0 {
                                tname = nrest;
                                nfrom = nlen;
                            } else {
                                tname = nrest[0..nnl];
                                nfrom = nfrom + nnl + 1;
                            }
                            if len(tname) > 0 {
                                let motion = r.name_to_motion(tname);
                                let entry = "{\"name\": \"" + tname
                                    + "\", \"motion\": \"" + motion
                                    + "\", \"file\": \"" + name + "\"}";
                                types_arr = __append_entry(types_arr, entry);
                            }
                        }
                    }
                }
            }
        }
    }

    let json = "{\n  \"dir\": \"" + dir + "\",\n  \"flavor\": \"" + flavor
        + "\",\n  \"domain\": {\n"
        + "    \"types\": [" + types_arr + "]\n"
        + "  }\n}";
    println(json);
}

locus DomainGraphL {
    params {
        dir: String = "apps/domain-graph/fixture";
        flavor: String = "go";
    }
    run() {
        __domain_drive(self.dir, self.flavor);
    }
}

fn main() {
    let mut dir = "apps/domain-graph/fixture";
    let mut flavor = "go";
    if std::env::args_count() > 1 {
        dir = std::env::arg(1);
    }
    if std::env::args_count() > 2 {
        flavor = std::env::arg(2);
    }
    DomainGraphL { dir: dir, flavor: flavor };
}
