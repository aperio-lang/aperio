// lib-fallible/parse.hl — fallible free fns, for testing
// or-on-Path callees (#66 regression).
//
// Consumer references these as `lp::parse_digit(...) or raise`,
// `lp::parse_digit(...) or fallback`, etc. The mangled symbols
// look like `__lib_lp_parse_parse_digit` after the cross-seed
// import rewrite.

type ParseError {
    kind: String;
    input: String;
}

fn parse_digit(s: String) -> Int fallible(ParseError) {
    if s == "0" { return 0; }
    if s == "1" { return 1; }
    if s == "2" { return 2; }
    if s == "3" { return 3; }
    if s == "4" { return 4; }
    if s == "5" { return 5; }
    if s == "6" { return 6; }
    if s == "7" { return 7; }
    if s == "8" { return 8; }
    if s == "9" { return 9; }
    fail ParseError { kind: "not_a_digit", input: s };
}
